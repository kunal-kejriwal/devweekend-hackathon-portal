# ─── APIEngine SDK Key ────────────────────────────────────────────────────────
# From: TheAPIEngine Dashboard → Developer Settings → SDK tab
# Used as X-API-Key header on all SDK Auth + custom-object calls
VITE_SDK_API_KEY=your_sdk_api_key_here

# ─── APIEngine Namespace ──────────────────────────────────────────────────────
# Your api_namespace from the spec (already pre-filled from your spec file)
VITE_API_NAMESPACE=58693b18-a130-4c58-bc83-94968e507a44

# ─── Frontend URL ─────────────────────────────────────────────────────────────
# Full URL of this app — used by APIEngine to build password-reset links in emails
# Set this same value in: TheAPIEngine Dashboard → Developer Settings → Frontend URL
VITE_FRONTEND_URL=http://localhost:5173

# ─── App name ─────────────────────────────────────────────────────────────────
VITE_APP_NAME=DevWeekend
